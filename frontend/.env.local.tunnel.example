# ─────────────────────────────────────────────────────────────────────────
# Single-URL tunnel demo (ngrok / zrok)
# Expose ONLY the frontend (port 3000). Next proxies /api and /uploads to the
# backend (see rewrites() in next.config.mjs), so everything is same-origin —
# no CORS, no cross-site cookie issues, ONE public URL to share.
#
# Usage:
#   1. Copy this file to frontend/.env.local
#   2. cd backend && npm run dev        (PROCESS_ROLE=all, port 5000)
#   3. cd frontend && npm run dev        (port 3000)
#   4. Tunnel the FRONTEND only:
#        ngrok:  ngrok http 3000
#        zrok:   zrok share public localhost:3000
#   Share the tunnel URL. (Restart `npm run dev` after editing this file.)
# ─────────────────────────────────────────────────────────────────────────

# Relative base → calls go to the tunnel origin and are proxied to the backend.
NEXT_PUBLIC_API_URL=/api/v1

# Enables the proxy in next.config.mjs rewrites(). REQUIRED for the single-URL
# setup. Leave UNSET in production so no rewrites are added there.
BACKEND_PROXY_ORIGIN=http://localhost:5000

# Clean client UI for demos: set true to hide the Agentation feedback overlay
# and the Next.js dev logo. Unset/false = normal dev tools. Dev-only.
NEXT_PUBLIC_CLEAN_UI=true

# Images:
# - Cloudinary images work as-is (absolute https URLs) — nothing to set.
# - If you serve local /uploads images instead, set this to your tunnel URL so
#   they resolve to the same origin and get proxied (update on each new URL):
# NEXT_PUBLIC_API_BASE=https://your-tunnel-url.ngrok-free.app

# Razorpay test key (online payments are optional for a demo; COD works without)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
