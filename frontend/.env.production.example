# Copy to frontend/.env.production on the VPS and replace values.

NEXT_PUBLIC_API_URL=https://api.thecakebake.in/api/v1
NEXT_PUBLIC_API_BASE=https://api.thecakebake.in
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_REPLACE

# Comma-separated image hostnames allowed by next/image.
NEXT_PUBLIC_IMAGE_DOMAINS=api.thecakebake.in,thecakebake.in,www.thecakebake.in,res.cloudinary.com
NEXT_PUBLIC_CDN_BASE_URL=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=REPLACE_WITH_CLOUD_NAME
