NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_API_BASE=http://localhost:5000
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx

# Auto-detect delivery location via the browser Geolocation API on first visit.
# Set to 'false' to disable (e.g. if the LocationIQ quota is exhausted); manual
# pincode entry keeps working. The LocationIQ token itself lives on the backend.
NEXT_PUBLIC_ENABLE_GEOLOCATION=true

# Optional production image/CDN settings
NEXT_PUBLIC_IMAGE_DOMAINS=api.thecakebake.in,thecakebake.in,www.thecakebake.in
NEXT_PUBLIC_CDN_BASE_URL=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
