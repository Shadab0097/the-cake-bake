# Server
NODE_ENV=development
# Runtime role: all for local dev; use web, worker, scheduler as separate VPS processes.
PROCESS_ROLE=all
PORT=5000
CORS_ORIGIN=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/cakebake
DB_POOL_SIZE=50
DB_MIN_POOL_SIZE=10
DB_SERVER_SELECTION_TIMEOUT_MS=5000
DB_SOCKET_TIMEOUT_MS=45000
DB_HEARTBEAT_FREQUENCY_MS=10000

# Scaling
CLUSTER_WORKERS=0

# JWT
JWT_SECRET=cakebake-jwt-secret-change-in-production
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=cakebake-refresh-secret-change-in-production
JWT_REFRESH_EXPIRE=30d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxx

# Online order expiry
ENABLE_ORDER_EXPIRY_JOB=true
ORDER_PAYMENT_EXPIRY_MINUTES=30
ORDER_EXPIRY_JOB_INTERVAL_MINUTES=5
ORDER_EXPIRY_BATCH_SIZE=100

# Payment reconciliation
ENABLE_PAYMENT_RECONCILIATION_JOB=true
PAYMENT_RECONCILIATION_INTERVAL_MINUTES=10
PAYMENT_RECONCILIATION_MIN_AGE_MINUTES=5
PAYMENT_RECONCILIATION_LOOKBACK_HOURS=72
PAYMENT_RECONCILIATION_BATCH_SIZE=100

# Stock reservation expiry
ENABLE_STOCK_RESERVATION_EXPIRY_JOB=true
STOCK_RESERVATION_EXPIRY_INTERVAL_MINUTES=5
STOCK_RESERVATION_EXPIRY_BATCH_SIZE=100

# Redis-backed production infrastructure
# Required in production for distributed rate limits, cache, and jobs.
REDIS_URL=
REDIS_TLS=false
REDIS_KEY_PREFIX=the-cake-bake
RATE_LIMIT_STORE=memory
CACHE_STORE=memory
CACHE_DEFAULT_TTL_SECONDS=60
JOB_QUEUE_MODE=inline
ENABLE_JOB_WORKER=true
JOB_WORKER_CONCURRENCY=5
JOB_DEFAULT_ATTEMPTS=3
JOB_BACKOFF_MS=5000
JOB_REMOVE_ON_COMPLETE_AGE_SECONDS=86400
JOB_REMOVE_ON_FAIL_AGE_SECONDS=604800

# Production-only escape hatches. Keep false unless intentionally running staging.
ALLOW_TEST_PAYMENT_KEYS=false
ALLOW_INSECURE_PRODUCTION_ORIGINS=false

# Optional internal token for GET /api/v1/health/readiness
HEALTH_CHECK_TOKEN=

# Optional operational alert webhook
OPERATIONAL_ALERT_WEBHOOK_URL=
OPERATIONAL_ALERT_WEBHOOK_TOKEN=
OPERATIONAL_ALERT_COOLDOWN_MINUTES=15
OPERATIONAL_ALERT_WEBHOOK_TIMEOUT_MS=3000

# Admin diagnostics: sanitized 5xx application error events only.
# TTL + fingerprint throttling prevent MongoDB growth during repeated failures.
ENABLE_APPLICATION_ERROR_EVENTS=true
APPLICATION_ERROR_RETENTION_DAYS=14
APPLICATION_ERROR_MIN_WRITE_INTERVAL_SECONDS=60
PAYMENT_WEBHOOK_EVENT_RETENTION_DAYS=90
PAYMENT_EMBEDDED_WEBHOOK_EVENT_LIMIT=50

# COD fraud and abuse controls
ENABLE_COD_ABUSE_CONTROLS=true
COD_MAX_ORDER_AMOUNT=500000
COD_REVIEW_ORDER_AMOUNT=250000
COD_PHONE_ORDER_LIMIT=5
COD_PHONE_ORDER_WINDOW_HOURS=24
COD_GUEST_IP_ORDER_LIMIT=3
COD_GUEST_IP_ORDER_WINDOW_HOURS=1
COD_ADDRESS_CANCEL_LIMIT=3
COD_ADDRESS_CANCEL_WINDOW_DAYS=30
COD_DISPOSABLE_EMAIL_DOMAINS=mailinator.com,tempmail.com,10minutemail.com,guerrillamail.com,yopmail.com

# Cancellation and refunds
CUSTOMER_CANCELLATION_CUTOFF_HOURS=12

# WhatsApp Cloud API
# Get credentials from: https://developers.facebook.com/ → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your-permanent-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_VERSION=v21.0
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
WHATSAPP_VERIFY_TOKEN=your-custom-webhook-verify-token
WHATSAPP_APP_SECRET=your-meta-app-secret

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Cloudinary image uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=the-cake-bake

# App
APP_NAME=The Cake Bake
APP_URL=http://localhost:3000
ADMIN_EMAIL=admin@cakebake.in

# ─────────────────────────────────────────────────────────────────────────────
# NOTIFICATION CHANNEL TOGGLES  (Global On/Off Control)
# Set each to true/false independently to control notification channels.
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_WHATSAPP_NOTIFICATIONS=false

# ─────────────────────────────────────────────────────────────────────────────
# NODEMAILER — Gmail SMTP (Development)
# For Gmail: enable 2-Step Verification → create App Password at:
#   https://myaccount.google.com/apppasswords
# In production, use a transactional service (SendGrid, Mailgun, Brevo)
# by updating SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS.
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Sender identity shown to customers
SMTP_FROM_NAME=The Cake Bake
SMTP_FROM_EMAIL=noreply@thecakebake.in

# ─────────────────────────────────────────────────────────────────────────────
# ADMIN ALERT RECIPIENTS
# Comma-separated list for new inquiry / order alert emails
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_ALERT_EMAILS=admin@cakebake.in,owner@cakebake.in

# ─────────────────────────────────────────────────────────────────────────────
# LOYALTY POINTS SYSTEM
# pointsPerRupee: How many points earned per rupee spent (0.01 = 1pt per ₹100)
# pointValue: Paise value of each point (100 = 1 point = ₹1)
# minRedeem: Minimum points balance required to redeem
# maxRedeemPercent: Max percentage of order total payable via points
# expiryDays: Days before points expire (0 = never expire)
# ─────────────────────────────────────────────────────────────────────────────
LOYALTY_POINTS_PER_RUPEE=0.01
LOYALTY_POINT_VALUE=100
LOYALTY_MIN_REDEEM=50
LOYALTY_MAX_REDEEM_PERCENT=20
LOYALTY_EXPIRY_DAYS=365

# ─────────────────────────────────────────────────────────────────────────────
# CHATBOT
# ─────────────────────────────────────────────────────────────────────────────
CHATBOT_FALLBACK_MESSAGE=Thank you for reaching out! 🎂 Our team will get back to you shortly.
