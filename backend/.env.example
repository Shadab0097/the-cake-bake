# Server
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/cakebake
DB_POOL_SIZE=50

# Scaling
CLUSTER_WORKERS=0

# JWT
JWT_SECRET=cakebake-jwt-secret-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=cakebake-refresh-secret-change-in-production
JWT_REFRESH_EXPIRE=30d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxx

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=your-permanent-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_VERSION=v21.0
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# App
APP_NAME=Cake Bake
APP_URL=http://localhost:3000
ADMIN_EMAIL=admin@cakebake.in
