# Copy to backend/.env on the VPS and replace every placeholder.
# The app intentionally refuses to boot in production with placeholders.

NODE_ENV=production
PROCESS_ROLE=web
PORT=5000
CORS_ORIGIN=https://thecakebake.in,https://www.thecakebake.in
APP_URL=https://thecakebake.in

MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER/thecakebake
DB_POOL_SIZE=20
DB_MIN_POOL_SIZE=2

REDIS_URL=redis://localhost:6379
REDIS_TLS=false
REDIS_KEY_PREFIX=the-cake-bake
RATE_LIMIT_STORE=redis
CACHE_STORE=redis
JOB_QUEUE_MODE=bullmq
ENABLE_JOB_WORKER=false
JOB_WORKER_CONCURRENCY=5

JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_64_CHAR_SECRET
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=30d

RAZORPAY_KEY_ID=rzp_live_REPLACE
RAZORPAY_KEY_SECRET=REPLACE_WITH_RAZORPAY_SECRET
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_RAZORPAY_WEBHOOK_SECRET

HEALTH_CHECK_TOKEN=REPLACE_WITH_RANDOM_HEALTH_TOKEN_32_CHARS

CLOUDINARY_CLOUD_NAME=REPLACE_WITH_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_API_SECRET
CLOUDINARY_FOLDER=the-cake-bake

# LocationIQ reverse geocoding (storefront auto-detect location).
# Leave LOCATIONIQ_API_KEY empty to disable; manual pincode entry still works.
LOCATIONIQ_API_KEY=REPLACE_WITH_LOCATIONIQ_TOKEN
LOCATIONIQ_BASE_URL=https://us1.locationiq.com/v1
LOCATIONIQ_TIMEOUT_MS=5000
LOCATIONIQ_CACHE_TTL_SECONDS=86400

ENABLE_ORDER_EXPIRY_JOB=true
ORDER_PAYMENT_EXPIRY_MINUTES=30
ORDER_EXPIRY_JOB_INTERVAL_MINUTES=5
ORDER_EXPIRY_BATCH_SIZE=100

ENABLE_PAYMENT_RECONCILIATION_JOB=true
PAYMENT_RECONCILIATION_INTERVAL_MINUTES=10
PAYMENT_RECONCILIATION_MIN_AGE_MINUTES=5
PAYMENT_RECONCILIATION_LOOKBACK_HOURS=72
PAYMENT_RECONCILIATION_BATCH_SIZE=100

ENABLE_STOCK_RESERVATION_EXPIRY_JOB=true
STOCK_RESERVATION_EXPIRY_INTERVAL_MINUTES=5
STOCK_RESERVATION_EXPIRY_BATCH_SIZE=100

ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=The Cake Bake
SMTP_FROM_EMAIL=noreply@thecakebake.in
ADMIN_ALERT_EMAILS=admin@thecakebake.in

ENABLE_WHATSAPP_NOTIFICATIONS=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=REPLACE_WITH_META_WEBHOOK_VERIFY_TOKEN
WHATSAPP_APP_SECRET=REPLACE_WITH_META_APP_SECRET

OPERATIONAL_ALERT_WEBHOOK_URL=
OPERATIONAL_ALERT_WEBHOOK_TOKEN=
OPERATIONAL_ALERT_COOLDOWN_MINUTES=15
OPERATIONAL_ALERT_WEBHOOK_TIMEOUT_MS=3000

# Admin diagnostics: only sanitized 5xx application errors are persisted.
# Keep retention short on small VPS MongoDB plans.
ENABLE_APPLICATION_ERROR_EVENTS=true
APPLICATION_ERROR_RETENTION_DAYS=14
APPLICATION_ERROR_MIN_WRITE_INTERVAL_SECONDS=60
PAYMENT_WEBHOOK_EVENT_RETENTION_DAYS=90
PAYMENT_EMBEDDED_WEBHOOK_EVENT_LIMIT=50

ENABLE_COD_ABUSE_CONTROLS=true
COD_MAX_ORDER_AMOUNT=500000
COD_REVIEW_ORDER_AMOUNT=250000
COD_PHONE_ORDER_LIMIT=5
COD_PHONE_ORDER_WINDOW_HOURS=24
COD_GUEST_IP_ORDER_LIMIT=3
COD_GUEST_IP_ORDER_WINDOW_HOURS=1
COD_ADDRESS_CANCEL_LIMIT=3
COD_ADDRESS_CANCEL_WINDOW_DAYS=30

CUSTOMER_CANCELLATION_CUTOFF_HOURS=12

ALLOW_TEST_PAYMENT_KEYS=false
ALLOW_INSECURE_PRODUCTION_ORIGINS=false
